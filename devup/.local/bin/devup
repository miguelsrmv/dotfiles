#!/usr/bin/env bash

# Exit if not inside a tmux session
if [ -z "$TMUX" ]; then
  echo "Error: This script must be run inside a tmux session." >&2
  exit 1
fi

# ── Layout dimensions ────────────────────────────────────────────────
# A|B top row = 85% of window height, C bottom = 15% (full width)
# A = 70% of window width, B = 30%

TOTAL_WIDTH=$(tmux display-message -p '#{window_width}')
TOTAL_HEIGHT=$(tmux display-message -p '#{window_height}')

TOP_HEIGHT=$(( TOTAL_HEIGHT * 85 / 100 ))
PANE_A_WIDTH=$(( TOTAL_WIDTH * 70 / 100 ))

# ── Build layout ─────────────────────────────────────────────────────
# Order matters: split vertically first so C spans the full width,
# then split the top portion horizontally into A and B.

PANE_A=$(tmux display-message -p '#{pane_id}')

# Step 1: vertical split of the whole window → C is full-width at bottom
PANE_C=$(tmux split-window -v -l $(( TOTAL_HEIGHT - TOP_HEIGHT )) -P -F '#{pane_id}')

# Step 2: horizontal split of the top pane → B on the right
tmux select-pane -t "$PANE_A"
PANE_B=$(tmux split-window -h -l $(( TOTAL_WIDTH - PANE_A_WIDTH )) -P -F '#{pane_id}')

# ── Launch apps ──────────────────────────────────────────────────────

# Pane B — opencode first, give it time to fully initialise its TUI
tmux select-pane -t "$PANE_B"
tmux send-keys "opencode" Enter

# Wait for opencode to finish drawing before nvim starts, so its TUI
# setup doesn't corrupt nvim's terminal state
sleep 2

# Pane A — nvim last, terminal is stable by now
tmux select-pane -t "$PANE_A"
tmux send-keys "nvim" Enter
