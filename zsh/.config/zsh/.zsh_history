sudo tee /usr/local/bin/batlog.sh > /dev/null << 'EOF'\
#!/bin/bash\
while true; do\
  echo "$(date '+%F %T') \\
V=$(cat /sys/class/power_supply/BAT0/voltage_now) \\
I=$(cat /sys/class/power_supply/BAT0/current_now) \\
cap=$(cat /sys/class/power_supply/BAT0/capacity) \\
status=$(cat /sys/class/power_supply/BAT0/status)" >> /var/log/batlog.txt\
  sync\
  sleep 2\
done\
EOF\
sudo chmod +x /usr/local/bin/batlog.sh\
\
sudo tee /etc/systemd/system/batlog.service > /dev/null << 'EOF'\
[Unit]\
Description=Battery state logger\
After=multi-user.target\
\
[Service]\
ExecStart=/usr/local/bin/batlog.sh\
Restart=always\
\
[Install]\
WantedBy=multi-user.target\
EOF\
\
