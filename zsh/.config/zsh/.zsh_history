while true; do\
    echo "$(date +%T) $(cat /sys/class/power_supply/BAT0/voltage_now) $(cat /sys/class/power_supply/BAT0/current_now)" >> ~/battery_log.txt\
    sleep 1\
done
tail -f 20 ./battery_log.txt
while true; do\
    echo -n "$(date +%T) V=$(cat /sys/class/power_supply/BAT0/voltage_now) " >> ~/system_log.txt\
    for z in /sys/class/thermal/thermal_zone*/; do\
        type=$(cat $z/type)\
        temp=$(awk '{printf "%.1f", $1/1000}' $z/temp)\
        echo -n "$type=${temp}C " >> ~/system_log.txt\
    done\
    echo >> ~/system_log.txt\
    sleep 1\
done
tail 20 ~/system_log.txt
