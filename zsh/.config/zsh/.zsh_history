ls -la
clear
for f in $(printf '%s\n' * | sort -Vr); do\
    if [[ $f =~ ^([0-9]+)(.*)$ ]]; then\
        num=${BASH_REMATCH[1]}\
        rest=${BASH_REMATCH[2]}\
\
        if (( num >= 32 )); then\
            mv -- "$f" "$((num + 1))$rest"\
        fi\
    fi\
done
ls -la
clear
find . -maxdepth 1 -type f -printf '%f\0' |\
sort -zr |\
while IFS= read -r -d '' f; do\
    if [[ $f =~ ^([0-9]+)(.*)$ ]]; then\
        num=${BASH_REMATCH[1]}\
        rest=${BASH_REMATCH[2]}\
\
        if (( num >= 32 )); then\
            echo mv -- "$f" "$((num + 1))$rest"\
        fi\
    fi\
done
for f in ${(On)~$(print -rl -- * | grep -E '^[0-9]+ - ')}; do\
    num=${f%% -*}\
    if (( num >= 32 )); then\
        mv -- "$f" "$((num + 1))${f#$num}"\
    fi\
done
ls -la
bash -c '\
find . -maxdepth 1 -type f -printf "%f\n" |\
sort -Vr |\
while IFS= read -r f; do\
    if [[ $f =~ ^([0-9]+)(.*)$ ]]; then\
        num=${BASH_REMATCH[1]}\
        (( num >= 32 )) && mv -- "$f" "$((num+1))${BASH_REMATCH[2]}"\
    fi\
done\
'
