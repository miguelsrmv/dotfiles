    echo "$(date +%T) $(cat /sys/class/power_supply/BAT0/voltage_now) $(cat /sys/class/power_supply/BAT0/current_now)" >> ~/battery_log.txt\
    sleep 1\
done
tail -f 20 ./battery_log.txt
while true; do\
    echo -n "$(date +%T) V=$(cat /sys/class/power_supply/BAT0/voltage_now) " >> ~/system_log.txt\
    for z in /sys/class/thermal/thermal_zone*/; do\
        type=$(cat $z/type)\
        temp=$(awk '{printf "%.1f", $1/1000}' $z/temp)\
        echo -n "$type=${temp}C " >> ~/system_log.txt\
    done\
    echo >> ~/system_log.txt\
    sleep 1\
done
tail 20 ~/system_log.txt
tail -n 30  ~/system_log.txt
clear
tail -n 50  ~/system_log.txt
clear ; tail -50  ~/system_log.txt
sudo dnf update
flatpak update -y
clear
while true; do\
    echo -n "$(date +%T) V=$(cat /sys/class/power_supply/BAT0/voltage_now) " >> ~/system_log.txt\
    for z in /sys/class/thermal/thermal_zone*/; do\
        type=$(cat $z/type)\
        temp=$(awk '{printf "%.1f", $1/1000}' $z/temp)\
        echo -n "$type=${temp}C " >> ~/system_log.txt\
    done\
    echo >> ~/system_log.txt\
    sleep 1\
done
cat /sys/power/mem_sleep
curl parrot.live
clear
sudo dnf update
flatpak update -y
nvim test_computer.sh
while true; do\
    echo -n "$(date +%T) V=$(cat /sys/class/power_supply/BAT0/voltage_now) " >> ~/system_log.txt\
    for z in /sys/class/thermal/thermal_zone*/; do\
        type=$(cat $z/type)\
        temp=$(awk '{printf "%.1f", $1/1000}' $z/temp)\
        echo -n "$type=${temp}C " >> ~/system_log.txt\
    done\
    echo >> ~/system_log.txt\
    sleep 1\
doneclear
nvim test_computer.sh
chmod +x test_computer.sh
clear
./test_computer.sh
nvim system_log.txt
nvim test_computer.sh
rm system_log.txt
clear
./test_computer.sh
nvim system_log.txt
nvim test_computer.sh
clear
./test_computer.sh
nvim system_log.txt
clear
rm system_log.txt
clear
