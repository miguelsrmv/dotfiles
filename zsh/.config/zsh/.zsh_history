  echo "=================================================="\
  journalctl -b -1 -n 250 --no-pager\
\
  echo -e "\n=================================================="\
  echo "3. THERMAL EVENTS FROM PREVIOUS BOOT"\
  echo "=================================================="\
  journalctl -b -1 | grep -iE "thermal|temperature|throttling|mce" | tail -n 50\
\
  echo -e "\n=================================================="\
  echo "4. POWER & BATTERY EVENTS FROM PREVIOUS BOOT"\
  echo "=================================================="\
  journalctl -b -1 | grep -iE "battery|upower|acpi|power" | tail -n 50\
\
  echo -e "\n=================================================="\
  echo "5. CURRENT BATTERY HEALTH STATUS"\
  echo "=================================================="\
  upower -i /org/freedesktop/UPower/devices/battery_BAT0\
\
  echo -e "\n=================================================="\
  echo "6. INSTALLING TOOLS & CHECKING HARDWARE TEMPERATURES"\
  echo "=================================================="\
  sudo dnf install -y lm_sensors smartmontools nvme-cli > /dev/null 2>&1\
  sudo sensors-detect --auto > /dev/null 2>&1\
  sensors\
\
  echo -e "\n=================================================="\
  echo "7. CRUCIAL SSD HEALTH REPORT"\
  echo "=================================================="\
  sudo smartctl -a /dev/nvme0\
\
  echo -e "\n=================================================="\
  echo "8. CRUCIAL SSD INTERNAL ERROR LOGS"\
  echo "=================================================="\
  sudo nvme error-log /dev/nvme0\
\
} > dell_diagnostic_log.txt\
