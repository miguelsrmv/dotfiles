curl -L -o woeusb.bash https://github.com/WoeUSB/WoeUSB/releases/download/v5.2.4/woeusb-5.2.4.bash
head -1 woeusb.bash      # must show: # (if it shows HTML, the version number is wrong â€ƒ´ check the releases page)
nvim woeusb.bash
chmod +x woeusb.bash
lsblk -o NAME,SIZE,TYPE,MOUNTPOINTS,TRA
lsblk -o NAME,SIZE,TYPE,MOUNTPOINTS,TRAN
sudo umount /dev/sda
sudo ./woeusb.bash --device ~/Downloads/Win11_25H2_EnglishInternational_x64_v2.iso /dev/sda --target-filesystem ntfs
sudo dnf install wimlib-utils\
which wimlib-imagex
clear
lsblk -o NAME,SIZE,TYPE,MOUNTPOINTS,TRAN
sudo umount /dev/sda*\
sudo ./woeusb.bash --device ~/Downloads/Win11_25H2_EnglishInternational_x64_v2.iso /dev/sda --target-filesystem ntfs
sync
opencode --port
ls
themeSwitcher
clear
