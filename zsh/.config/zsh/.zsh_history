for f in $(printf '%s\n' * | sort -Vr); do\
    if [[ $f =~ ^([0-9]+)(.*)$ ]]; then\
        num=${BASH_REMATCH[1]}\
        rest=${BASH_REMATCH[2]}\
\
        if (( num >= 32 )); then\
            mv -- "$f" "$((num + 1))$rest"\
        fi\
    fi\
done
