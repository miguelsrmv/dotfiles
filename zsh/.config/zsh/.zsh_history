clear
find . -maxdepth 1 -type f -printf '%f\0' |\
sort -zr |\
while IFS= read -r -d '' f; do\
    if [[ $f =~ ^([0-9]+)(.*)$ ]]; then\
        num=${BASH_REMATCH[1]}\
        rest=${BASH_REMATCH[2]}\
\
        if (( num >= 32 )); then\
            echo mv -- "$f" "$((num + 1))$rest"\
        fi\
    fi\
done
for f in ${(On)~$(print -rl -- * | grep -E '^[0-9]+ - ')}; do\
    num=${f%% -*}\
    if (( num >= 32 )); then\
        mv -- "$f" "$((num + 1))${f#$num}"\
    fi\
done
